# ---------------------------------------------------------------------------
# NotionTodoApp – environment proměnné
# Zkopíruj do `.env` a doplň hodnoty. `.env` NIKDY necommituj.
# Tyto klíče se ve výrobě nastavují jako GitHub Secrets (viz PLAN.md 0.7).
# ---------------------------------------------------------------------------

# Běhové prostředí: development | production | test
NODE_ENV=development

# HTTP port backend API
PORT=3000

# Cesta k SQLite souboru (jen auth data – users, sessions, notion_configs)
DATABASE_PATH=./data/app.sqlite

# URL frontendu – jediný povolený CORS origin
FRONTEND_URL=http://localhost:5173

# JWT podpisový klíč  ->  openssl rand -base64 64
JWT_SECRET=

# Šifrovací klíč pro Notion token (AES-256-GCM, 32 bajtů hex)  ->  openssl rand -hex 32
NOTION_ENCRYPTION_KEY=

# Google OAuth 2.0 (web client) – Google Cloud Console (viz PLAN.md 1.3)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Google OAuth iOS client ID (pro /auth/mobile ověření id_token aud)
GOOGLE_IOS_CLIENT_ID=
